# ==========================================
# 生产环境配置文件
# ==========================================
# 使用方式：npm run build 自动加载此文件
# 部署后 API 地址只改这一处即可

# API 基础地址（部署到生产服务器后的完整地址）
VITE_API_BASE_URL=https://xxx.xxx.xxx/api

# 应用标题
VITE_APP_TITLE=天气与出行助手智能体系统

# 运行模式
VITE_APP_ENV=production

# 是否开启接口 Mock
VITE_USE_MOCK=false

# 是否开启 Debug 日志
VITE_DEBUG=false

# ==========================================
# 高德地图 JSAPI 配置（前端地图渲染用）
# ==========================================
# 注意：JSAPI Key 与后端 WebService Key 是不同的 Key！
# 需在高德控制台 → 应用管理 → 创建「Web端(JS API)」类型的 Key
VITE_AMAP_JSAPI_KEY=请填入你的JSAPI_KEY
VITE_AMAP_SECURITY_CODE=请填入你的安全密钥
