# ==========================================
# 开发环境配置文件
# ==========================================
# 使用方式：npm run dev 自动加载此文件
# 变量必须带 VITE_ 前缀才能被客户端代码访问

# API 基础地址（开发时走 Vite proxy → localhost:8000）
VITE_API_BASE_URL=/api

# 应用标题
VITE_APP_TITLE=天气与出行助手智能体系统 [DEV]

# 运行模式
VITE_APP_ENV=development

# 是否开启接口 Mock（暂不使用）
VITE_USE_MOCK=false

# 是否开启 Debug 日志
VITE_DEBUG=true

# ==========================================
# 高德地图 JSAPI 配置（前端地图渲染用）
# ==========================================
# 注意：JSAPI Key 与后端 WebService Key 是不同的 Key！
# 需在高德控制台 → 应用管理 → 创建「Web端(JS API)」类型的 Key
# 申请地址：https://console.amap.com/dev/key/app
VITE_AMAP_JSAPI_KEY=acd28ac7c96e0453cd72a95b9e91e3b6
VITE_AMAP_SECURITY_CODE=f82e2d436f62484355a303b8ba3f2c18
